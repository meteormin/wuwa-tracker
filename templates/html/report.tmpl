<!DOCTYPE html>
<html lang="{{.Lang}}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{t "report.html_title"}}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', 'Noto Sans KR', sans-serif;
        }
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(30, 41, 59, 0.5);
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(148, 163, 184, 0.3);
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(148, 163, 184, 0.5);
        }
    </style>
</head>
<body class="bg-[#0b0f19] text-slate-100 min-h-screen p-4 md:p-8">
    <div class="max-w-6xl mx-auto">
        <!-- 헤더 -->
        <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8 border-b border-slate-800 pb-6">
            <div>
                <div class="flex items-center gap-2 mb-1">
                    <span class="inline-flex h-3 w-3 rounded-full bg-indigo-500 animate-pulse"></span>
                    <span class="text-xs font-semibold tracking-wider text-indigo-400 uppercase">Wuthering Waves</span>
                </div>
                <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight bg-gradient-to-r from-white via-slate-200 to-indigo-400 bg-clip-text text-transparent">
                    {{t "report.title"}} {{if .PlayerID}}<span class="text-xl md:text-2xl text-slate-400 font-medium block sm:inline sm:ml-2">({{t "report.player_id" "playerId" .PlayerID}})</span>{{end}}
                </h1>
            </div>
            <div class="text-xs text-slate-500 text-left md:text-right bg-slate-900/40 p-3 rounded-lg border border-slate-800">
                <p>{{t "report.created_by"}}</p>
                <p class="mt-1">{{t "header.timezone_warning"}}</p>
            </div>
        </header>

        <!-- 배너별 리포트 카드 렌더링 영역 -->
        <div class="space-y-12">
            {{range $index, $stat := .Stats}}
            <div class="bg-[#111625] border border-slate-800 rounded-2xl p-6 shadow-xl relative overflow-hidden transition-all duration-300 hover:border-slate-700/80" id="banner-card-{{$index}}">
                <!-- 배너 헤더 -->
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6 border-b border-slate-800/60 pb-4">
                    <h3 class="text-xl md:text-2xl font-bold text-slate-100 flex items-center gap-2">
                        <span class="w-2 h-6 bg-indigo-500 rounded"></span>
                        {{ $stat.GachaName }}
                    </h3>
                    <span class="text-xs font-semibold text-slate-500 bg-slate-900 px-3 py-1 rounded-full border border-slate-800">
                        {{t "report.type_code" "code" $stat.GachaType}}
                    </span>
                </div>

                <!-- 핵심 지표 요약 대시보드 -->
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
                    <div class="bg-slate-900/40 p-4 rounded-xl border border-slate-800/50">
                        <p class="text-xs text-slate-500 mb-1">{{t "report.total_pulls"}}</p>
                        <p class="text-2xl font-extrabold text-slate-100">{{ $stat.TotalPulls }}</p>
                    </div>
                    <div class="bg-slate-900/40 p-4 rounded-xl border border-slate-800/50">
                        <p class="text-xs text-slate-500 mb-1">{{t "report.current_pity"}}</p>
                        <p class="text-2xl font-extrabold text-amber-400">{{ $stat.CurrentPity5 }}<span class="text-xs text-slate-500 font-normal">{{t "report.pity_suffix"}}</span></p>
                    </div>
                    <!-- 동적 계산 영역 (운 점수 등) -->
                    {{- $luckBgClass := "bg-slate-900/40 border-slate-800/50" -}}
                    {{- $luckColorClass := "text-slate-400" -}}
                    {{- $luckMessage := "-" -}}
                    {{- $luckState := "normal" -}}
                    {{- if $stat.HasFiveStar -}}
                        {{- range $.LuckScoreThresholds -}}
                            {{- if ge $stat.LuckScore .MinScore -}}
                                {{- $luckState = .State -}}
                            {{- end -}}
                        {{- end -}}
                    {{- end}}
                    {{- if eq $luckState "worst" -}}
                        {{- $luckBgClass = "bg-rose-500/10 border-rose-500/30" -}}
                        {{- $luckColorClass = "text-rose-500 font-extrabold" -}}
                        {{- $luckMessage = (t "report.luck_score_state.worst") -}}
                    {{- else if eq $luckState "bad" -}}
                        {{- $luckBgClass = "bg-rose-500/5 border-rose-500/10" -}}
                        {{- $luckColorClass = "text-rose-300" -}}
                        {{- $luckMessage = (t "report.luck_score_state.bad") -}}
                    {{- else if eq $luckState "good" -}}
                        {{- $luckBgClass = "bg-emerald-500/5 border-emerald-500/20" -}}
                        {{- $luckColorClass = "text-emerald-400" -}}
                        {{- $luckMessage = (t "report.luck_score_state.good") -}}
                    {{- else if eq $luckState "best" -}}
                        {{- $luckBgClass = "bg-emerald-500/10 border-emerald-500/30" -}}
                        {{- $luckColorClass = "text-emerald-400" -}}
                        {{- $luckMessage = (t "report.luck_score_state.best") -}}
                    {{- else -}}
                        {{- $luckBgClass = "bg-slate-900/40 border-slate-800/50" -}}
                        {{- $luckColorClass = "text-slate-300" -}}
                        {{- $luckMessage = (t "report.luck_score_state.normal") -}}
                    {{- end -}}

                    <div class="p-4 rounded-xl border transition-all duration-300 {{$luckBgClass}}" id="luck-card-{{$index}}">
                        <div class="flex items-center gap-1 mb-1">
                            <span class="text-xs text-slate-500">{{t "report.luck_score"}}</span>
                            <div class="group relative cursor-pointer">
                                <svg class="w-3.5 h-3.5 text-slate-500 hover:text-slate-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                                <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-64 bg-slate-950 border border-slate-800 p-3 rounded-lg text-[11px] leading-relaxed text-slate-300 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all duration-200 shadow-2xl z-30 font-normal">
                                    <p class="font-bold text-indigo-400 mb-1">{{t "report.luck_score_formula_title"}}</p>
                                    <p class="mb-1.5"><code class="bg-slate-900 px-1.5 py-0.5 rounded text-indigo-400 font-mono text-[10px]">{{t "report.luck_score_formula"}}</code></p>
                                    <p class="mb-1">{{t "report.luck_score_description"}}</p>
                                    <p class="text-rose-400 border-t border-slate-800/80 pt-1 mt-1">{{t "report.luck_score_pity_warn"}}</p>
                                    <div class="absolute top-full left-1/2 -translate-x-1/2 -mt-1 border-4 border-transparent border-t-slate-950"></div>
                                </div>
                            </div>
                        </div>
                        <p class="text-2xl font-extrabold text-slate-400" id="luck-val-{{$index}}">
                            {{if $stat.HasFiveStar}}
                                <span class="{{$luckColorClass}}">{{$luckMessage}}</span> 
                                <span class="text-[10px] text-slate-500 block sm:inline font-normal">({{printf "%.0f" $stat.LuckScore}}%)</span>
                            {{else}}
                                <span class="text-slate-500 italic">{{t "report.luck_score_unknown"}}</span>
                            {{end}}
                        </p>
                    </div>
                </div>

                <!-- 획득 확률 분석 지표 -->
                <div class="bg-slate-950/50 rounded-xl border border-slate-850 p-4 mb-8">
                    <h4 class="text-xs font-bold text-indigo-400 uppercase tracking-wider mb-3">{{t "report.efficiency_analysis"}}</h4>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm">
                        <div class="flex justify-between sm:flex-col sm:justify-start gap-1">
                            <span class="text-slate-500 text-xs">{{t "report.my_avg_pulls"}}</span>
                            <span class="font-bold text-slate-200" id="avg-pulls-{{$index}}">
                                {{- if $stat.HasFiveStar -}}
                                    <span class="text-amber-400 font-extrabold">{{printf "%.1f" $stat.AvgPulls}}</span>{{t "report.avg_pulls_suffix"}} <span class="text-xs text-slate-500">{{t "report.avg_pulls_accumulated" "count" (len $stat.FiveStars)}}</span>
                                {{- else -}}
                                    <span class="text-slate-500 italic">{{t "report.no_avg_pulls"}}</span>
                                {{- end -}}
                            </span>
                        </div>
                        <div class="flex justify-between sm:flex-col sm:justify-start gap-1">
                            <span class="text-slate-500 text-xs">{{t "report.expected_avg_pulls"}}</span>
                            <span class="font-bold text-slate-200" id="expected-pulls-{{$index}}">{{ $stat.ExpectedPulls }}{{t "report.avg_pulls_suffix"}}</span>
                        </div>
                        <div class="flex justify-between sm:flex-col sm:justify-start gap-1">
                            <span class="text-slate-500 text-xs">{{t "report.actual_rate_vs_base"}}</span>
                            <span class="font-bold text-slate-200" id="rate-compare-{{$index}}">
                                {{- if $stat.HasFiveStar -}}
                                    {{- $rateClass := "text-rose-400" -}}
                                    {{- if ge $stat.ActualRate $stat.BaseRate -}}
                                        {{- $rateClass = "text-emerald-400" -}}
                                    {{- end -}}
                                    <span class="{{$rateClass}} font-extrabold">{{printf "%.2f" $stat.ActualRate}}%</span> <span class="text-xs text-slate-500">/ {{printf "%.1f" $stat.BaseRate}}%</span>
                                {{- else -}}
                                    <span class="text-slate-500">0.00% / {{printf "%.1f" $stat.BaseRate}}%</span>
                                {{- end -}}
                            </span>
                        </div>
                    </div>
                </div>

                <!-- 5성 히스토리 세션 -->
                <div class="mb-8">
                    <h4 class="text-sm font-bold text-slate-400 mb-3 flex items-center gap-2">
                        <span class="w-1.5 h-1.5 bg-amber-500 rounded-full animate-ping"></span>
                        {{t "report.history_title" "count" (len $stat.FiveStars)}}
                    </h4>
                    {{if $stat.FiveStars}}
                    <div class="overflow-hidden border border-slate-800/80 rounded-xl bg-slate-950/30">
                        <table class="min-w-full divide-y divide-slate-800">
                            <thead class="bg-slate-900/60">
                                <tr>
                                    <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">{{t "table.name"}}</th>
                                    <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">{{t "table.pity"}}</th>
                                    <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">{{t "table.time"}}</th>
                                    <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">{{t "table.category"}}</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-800/60 bg-transparent">
                                {{range $stat.FiveStars}}
                                <tr class="hover:bg-slate-900/20 transition-colors">
                                    <td class="px-4 py-3.5 whitespace-nowrap text-sm font-bold text-amber-400 flex items-center gap-1.5">
                                        <svg class="w-4 h-4 text-amber-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                                        {{.Name}}
                                    </td>
                                    <td class="px-4 py-3.5 whitespace-nowrap text-sm text-slate-200">
                                        <span class="font-extrabold text-amber-500 bg-amber-500/10 px-2 py-0.5 rounded border border-amber-500/20">{{t "table.pity_suffix" "count" .Pity}}</span>
                                    </td>
                                    <td class="px-4 py-3.5 whitespace-nowrap text-xs text-slate-400">{{.Time}}</td>
                                    <td class="px-4 py-3.5 whitespace-nowrap text-sm">
                                        {{if .IsPickUp}}
                                        <span class="px-2.5 py-0.5 inline-flex text-xs leading-5 font-semibold rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">{{t "table.pickup_success"}}</span>
                                        {{else}}
                                        <span class="px-2.5 py-0.5 inline-flex text-xs leading-5 font-semibold rounded-full bg-rose-500/10 text-rose-400 border border-rose-500/20">{{t "table.pickup_fail"}}</span>
                                        {{end}}
                                    </td>
                                </tr>
                                {{end}}
                            </tbody>
                        </table>
                    </div>
                    {{else}}
                    <div class="bg-slate-950/20 border border-dashed border-slate-800 rounded-xl p-6 text-center text-slate-500 text-sm">
                        {{t "report.history_empty"}}
                    </div>
                    {{end}}
                </div>

                <!-- 전체 히스토리 접기/펼치기 섹션 -->
                <details class="mt-6 border border-slate-800/80 rounded-xl overflow-hidden bg-slate-950/20 group">
                    <summary class="flex justify-between items-center p-4 font-bold text-slate-300 cursor-pointer hover:bg-slate-900/40 select-none transition-colors duration-200">
                        <span class="flex items-center gap-2 text-sm md:text-base">
                            <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                            {{t "full_history.title" "count" (len $stat.Records)}}
                        </span>
                        <span class="transition-transform duration-200 group-open:rotate-180">
                            <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </span>
                    </summary>
                    <div class="border-t border-slate-800/60 bg-[#0c0f17] max-h-96 overflow-y-auto custom-scrollbar">
                        {{if $stat.Records}}
                        <table class="min-w-full divide-y divide-slate-900">
                            <thead class="bg-slate-950/80 sticky top-0 z-10">
                                <tr>
                                    <th class="px-4 py-2.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">{{t "table.name"}}</th>
                                    <th class="px-4 py-2.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">{{t "table.rarity"}}</th>
                                    <th class="px-4 py-2.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">{{t "table.type"}}</th>
                                    <th class="px-4 py-2.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">{{t "table.time"}}</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-900 bg-transparent">
                                {{range $stat.Records}}
                                <tr class="hover:bg-slate-900/30 transition-colors {{if eq .QualityLevel 5}}bg-amber-500/5{{else if eq .QualityLevel 4}}bg-purple-500/5{{end}}">
                                    <td class="px-4 py-2 whitespace-nowrap text-sm {{if eq .QualityLevel 5}}font-bold text-amber-400{{else if eq .QualityLevel 4}}font-semibold text-purple-300{{else}}text-slate-300{{end}}">
                                        {{.Name}}
                                    </td>
                                    <td class="px-4 py-2 whitespace-nowrap text-xs">
                                        {{if eq .QualityLevel 5}}
                                        <span class="px-2 py-0.5 inline-flex leading-4 font-bold rounded bg-amber-500/10 text-amber-400 border border-amber-500/20">5★</span>
                                        {{else if eq .QualityLevel 4}}
                                        <span class="px-2 py-0.5 inline-flex leading-4 font-semibold rounded bg-purple-500/10 text-purple-300 border border-purple-500/20">4★</span>
                                        {{else}}
                                        <span class="px-2 py-0.5 inline-flex leading-4 rounded bg-slate-800 text-slate-400 border border-slate-700/50">3★</span>
                                        {{end}}
                                    </td>
                                    <td class="px-4 py-2 whitespace-nowrap text-xs text-slate-400">{{.ResourceType}}</td>
                                    <td class="px-4 py-2 whitespace-nowrap text-[11px] text-slate-500">{{.Time}}</td>
                                </tr>
                                {{end}}
                            </tbody>
                        </table>
                        {{else}}
                        <div class="p-6 text-center text-slate-500 text-sm">
                            {{t "full_history.empty"}}
                        </div>
                        {{end}}
                    </div>
                </details>
            </div>
            {{end}}
        </div>
    </div>
</body>
</html>
